# Copy this file to .env and add your API key

# Option 1: Use OpenAI (GPT-4)
OPENAI_API_KEY=your-openai-api-key-here

# Option 2: Use Anthropic (Claude) - recommended for better quality
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Which AI to use: openai or anthropic
AI_PROVIDER=openai

# Database location
DATABASE_PATH=database/sage_reports.db

# Server settings
FLASK_PORT=5000
FLASK_HOST=127.0.0.1
